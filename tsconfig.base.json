{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "strictNullChecks": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2022",
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "experimentalDecorators": true,
    "importHelpers": true,
    "paths": {
      "@vm-components": ["libs/vm-components/src/index.ts"],
      "@vm-parts": ["libs/vm-parts/src/index.ts"],
      "@vm-utils": ["libs/vm-utils/src/index.ts"],
      "@vm-utils/dialogs": ["libs/vm-utils/dialogs/src/index.ts"],
      "@vm-utils/snackbar": ["libs/vm-utils/snackbar/src/index.ts"],
      "@vm-utils/services": ["libs/vm-utils/services/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "strictTemplates": true,
    "strictInjectionParameters": true,
    "strictInputTypes": true,
    "strictOutputEventTypes": true,
    "strictDomEventTypes": true,
    "enableI18nLegacyMessageIdFormat": false
  }
}
